# deployments/<your-profile>/.env
#
# Template environment file for a custom entropy source.
# Copy this file to .env and fill in your server's details:
#   cp .env.example .env
#
# Required edits for most custom servers:
#   1. QR_GRPC_SERVER_ADDRESS
#   2. QR_GRPC_METHOD_PATH
#   3. QR_GRPC_STREAM_METHOD_PATH (or leave empty if unused)
#   4. QR_GRPC_API_KEY if your server requires auth

# --- Hugging Face ---
HF_MODEL=Qwen/Qwen2.5-1.5B-Instruct
HF_TOKEN=

# --- Entropy source ---
QR_ENTROPY_SOURCE_TYPE=quantum_grpc

# Your gRPC entropy server address. Use the Docker service name if
# the server is co-located (e.g., entropy-server:50051), or an IP/hostname
# if external (e.g., 10.0.0.100:50051).
QR_GRPC_SERVER_ADDRESS=localhost:50051

# gRPC method paths — must match your server's proto definition.
# Format: /<package>.<Service>/<Method>
QR_GRPC_METHOD_PATH=/qr_entropy.EntropyService/GetEntropy
QR_GRPC_STREAM_METHOD_PATH=/qr_entropy.EntropyService/StreamEntropy

# --- Authentication (leave empty if not required) ---
QR_GRPC_API_KEY=

# Fall back to system entropy if the gRPC server is unreachable.
QR_FALLBACK_MODE=system

# --- Sampling parameters ---
QR_TEMPERATURE_STRATEGY=fixed
QR_FIXED_TEMPERATURE=0.7
QR_TOP_K=0
QR_TOP_P=1.0
QR_LOG_LEVEL=summary

# --- Optional advanced settings (defaults shown) ---
# QR_GRPC_MODE=unary
# QR_GRPC_TIMEOUT_MS=5000
# QR_GRPC_API_KEY_HEADER=api-key
# QR_SAMPLE_COUNT=20480

# --- Ports (host-side) ---
VLLM_PORT=8000
# ENTROPY_SERVER_PORT=50051  # Uncomment if using a co-located server

# --- Open WebUI (optional, --profile ui) ---
OPEN_WEBUI_PORT=3000
# Set to true to require login (recommended for shared/public servers).
OPEN_WEBUI_AUTH=false
