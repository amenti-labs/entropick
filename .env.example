# Minimal bare-metal configuration for entropick.
#
# Copy to .env, then export it before launching vLLM:
#   cp .env.example .env
#   set -a; source .env; set +a
#
# For other entropy sources, start from:
#   .env.grpc.example
#   .env.openentropy.example

HF_MODEL=Qwen/Qwen2.5-1.5B-Instruct
HF_TOKEN=

# --- Core entropick settings ---
QR_ENTROPY_SOURCE_TYPE=system
QR_FALLBACK_MODE=system
QR_TEMPERATURE_STRATEGY=fixed
QR_FIXED_TEMPERATURE=0.7
QR_TOP_K=0
QR_TOP_P=1.0
QR_LOG_LEVEL=summary

# --- Optional advanced settings ---
# QR_SAMPLE_COUNT=20480
# QR_DIAGNOSTIC_MODE=false
